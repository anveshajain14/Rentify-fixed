PORT=5000
NODE_ENV=production

# Public URLs
API_PUBLIC_URL=https://rentify-fixed.onrender.com
FRONTEND_URL=https://rentify-fixed-6wro.vercel.app

# Comma-separated list. Supports wildcard for all Vercel previews:
# https://*.vercel.app
CORS_ALLOWED_ORIGINS=https://rentify-fixed-6wro.vercel.app,https://*.vercel.app

# Core secrets
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/rentify
JWT_SECRET=replace_with_secure_secret

# Optional debug flags (set to true temporarily)
DEBUG_CORS=false

# Optional integrations
FASTAPI_BASE_URL=https://your-fastapi.onrender.com
PYTHON_AI_URL=https://your-fastapi.onrender.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_USER=
EMAIL_PASS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
